/*Librerias*/
#include <Arduino.h>
#include <stdio.h>
#include <stdint.h>

/*Definiciones*/
const int ledA=33;
const int ledB=25;
const int ledC=26;
const int ledD=27;

const int botonIN=34; //incrementa
const int botonDE=35; //decrementa
const int botonM=32; //cambia de modo

/*Variables globales*/
int8_t contador = 0;
uint8_t modo = 1;

int nuevoestadoIN = LOW;
int nuevoestadoDE = LOW;
int nuevoestadoM = LOW;

//matriz de numeros binarios del 0 al 15 (4 bits, 2^4 = 16 combinaciones o numeros)
const int contadorbinario[16][4]={
{LOW,LOW,LOW,LOW}, //0
{LOW,LOW,LOW,HIGH}, //1
{LOW,LOW,HIGH,LOW}, //2
{LOW,LOW,HIGH,HIGH}, //3
{LOW,HIGH,LOW,LOW}, //4
{LOW,HIGH,LOW,HIGH}, //5
{LOW,HIGH,HIGH,LOW}, //6
{LOW,HIGH,HIGH,HIGH}, //7
{HIGH,LOW,LOW,LOW}, //8
{HIGH,LOW,LOW,HIGH}, //9
{HIGH,LOW,HIGH,LOW}, //10
{HIGH,LOW,HIGH,HIGH}, //11
{HIGH,HIGH,LOW,LOW}, //12
{HIGH,HIGH,LOW,HIGH}, //13
{HIGH,HIGH,HIGH,LOW}, //14
{HIGH,HIGH,HIGH,HIGH}, //15
};

/*Funcion principal*/
void setup(){

pinMode(botonIN,INPUT);
pinMode(botonDE,INPUT);
pinMode(botonM, INPUT_PULLDOWN);

pinMode(ledA,OUTPUT);
pinMode(ledB,OUTPUT);
pinMode(ledC,OUTPUT);
pinMode(ledD,OUTPUT);
}

void loop(){

int estadoIN = digitalRead(botonIN);
int estadoDE = digitalRead(botonDE);
int estadoM = digitalRead(botonM);

if(estadoM==HIGH && nuevoestadoM==LOW){
  delay(50);
  estadoM = digitalRead(botonM);
  if(estadoM==HIGH){
    modo++;
    if(modo>2){
      modo=1;
    }
    contador=0;
  }
}
nuevoestadoM = estadoM; //actualizo boton


//Incremento
if(estadoIN==HIGH && nuevoestadoIN==LOW){
  delay(50);
  estadoIN = digitalRead(botonIN);
  if(estadoIN==HIGH){
   contador++;
      
    if(modo==1 && contador>4){
        contador=0; //limito el maximo del contador
    }
    else if (modo==2 && contador>15){ //evaluo limite segun modo
      contador=0;
    }      
  }
}

//Decremento
if(estadoDE==HIGH && nuevoestadoDE==LOW){
  delay(50);
  estadoDE = digitalRead(botonDE);
  if(estadoDE==HIGH){
    contador--;
   
    if(modo==1 && contador<0){
        contador=4;
    } //limito el minimo del contador en modo 1
    else if (modo==2 && contador<0){
      contador=15;
    }
  }
}

nuevoestadoIN=estadoIN;  //actualizo estado de los botones
nuevoestadoDE=estadoDE; 

if(modo==1){
  switch (contador) {
      case 0:
        digitalWrite(ledA, LOW);
        digitalWrite(ledB, LOW);
        digitalWrite(ledC, LOW);
        digitalWrite(ledD, LOW);
        break;
      case 1:
        digitalWrite(ledA, HIGH);
        digitalWrite(ledB, LOW);
        digitalWrite(ledC, LOW);
        digitalWrite(ledD, LOW);
        break;
      case 2:
        digitalWrite(ledA, LOW);
        digitalWrite(ledB, HIGH);
        digitalWrite(ledC, LOW);
        digitalWrite(ledD, LOW);
        break;
      case 3:
        digitalWrite(ledA, LOW);
        digitalWrite(ledB, LOW);
        digitalWrite(ledC, HIGH);
        digitalWrite(ledD, LOW);
        break;
      case 4:
        digitalWrite(ledA, LOW);
        digitalWrite(ledB, LOW);
        digitalWrite(ledC, LOW);
        digitalWrite(ledD, HIGH);
        break;
  }
}

else if(modo==2){
  const int bitsbinarios[4]={ledA,ledB,ledC,ledD}; //arreglo con pines de led para simular bits significativos

  for (int i = 0; i < 4; i++) {
      digitalWrite(bitsbinarios[i], contadorbinario[contador][i]); //recorre los 4 leds
    }
}
}